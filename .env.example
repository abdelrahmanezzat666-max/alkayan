# Firebase
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_SERVICE_ACCOUNT_PATH="your-local-service-account-file.json"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-service-account-private-key\n-----END PRIVATE KEY-----\n"

# API
NODE_ENV="development"
PORT=4000
API_URL="http://localhost:4000"
APP_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
JWT_SECRET="replace-with-a-random-64-character-secret-for-production"
JWT_EXPIRES_IN="8h"
INVITATION_EXPIRES_HOURS=48

# Initial admin seed
ADMIN_NAME="Al Kayan Admin"
ADMIN_EMAIL="admin@alkayan.local"
ADMIN_PASSWORD="ChangeMe123!"

# Email invitations. Leave empty in development to log invitation previews.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Al Kayan <no-reply@alkayan.local>"
